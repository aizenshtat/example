{
  "name": "crowdship-example",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "build:preview": "tsc --noEmit && vite build --mode preview",
    "deploy:preview": "bash scripts/deploy-preview.sh",
    "preview": "vite preview --host 0.0.0.0",
    "quality": "bash scripts/quality-check.sh",
    "smoke:preview": "node scripts/preview-runtime-smoke.mjs",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && bash -n scripts/*.sh .githooks/pre-commit"
  },
  "dependencies": {
    "@sentry/browser": "^10.49.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
